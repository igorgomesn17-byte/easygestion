# ============================================================
# Variáveis de ambiente — COPIE para .env e preencha.
# NUNCA comite o .env de verdade (está no .gitignore).
# No Render, configure cada uma em "Environment".
# ============================================================

# Ambiente (em produção use 'production' — ativa cookie seguro/HTTPS)
NODE_ENV=production

# Porta (o Render injeta automaticamente; localmente usa 3000)
PORT=3000

# Senha de acesso ao sistema (você escolhe — use uma forte***REMOVED***)
# Ex: ADMIN_SENHA=MinhaSenhaForte#2026
ADMIN_SENHA=troque-esta-senha

# Segredo da sessão (string longa e aleatória — gere uma única)
# Dica: rode no terminal -> node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cole-aqui-uma-string-bem-longa-e-aleatoria

# Diretório do banco e das fotos (disco persistente do Render = /data)
DB_DIR=/data
UPLOADS_DIR=/data/produtos

# Domínio público (para o CORS). Ex: https://oficialdsstore.com.br
ORIGIN=https://oficialdsstore.com.br

# ============================================================
# INBOX — APIs oficiais da Meta (WhatsApp Cloud API + Instagram)
# Deixe em branco enquanto não tiver: o inbox funciona em "modo
# registro" (guarda conversas), mas só ENVIA/RECEBE via Meta quando
# estas estiverem preenchidas. Obtidas no painel Meta for Developers.
# ============================================================

# --- WhatsApp Cloud API ---
WHATSAPP_TOKEN=                 # Access token (system user, longa duração)
WHATSAPP_PHONE_ID=             # PHONE_NUMBER_ID do número no WABA
WABA_ID=                       # WhatsApp Business Account ID

# --- Instagram Messaging API ---
INSTAGRAM_TOKEN=               # Access token do Instagram
INSTAGRAM_ID=                  # IG ID da conta profissional

# --- Comum aos webhooks da Meta ---
META_VERIFY_TOKEN=             # string que VOCÊ inventa (confirma o webhook na Meta)
META_APP_SECRET=               # App Secret (valida a assinatura X-Hub-Signature-256)
META_GRAPH_VERSION=v21.0       # versão da Graph API (opcional)

# ============================================================
# NFC-e — Focus NFe (emissão de cupom fiscal eletrônico)
# Os TOKENS são segredo: pegue no painel da Focus (aba TOKENS).
# Há um token por ambiente. Deixe em branco enquanto não usar:
# o sistema só emite quando o token do ambiente atual estiver aqui.
# O ambiente atual (homologacao/producao) é escolhido na tela Config.
# ============================================================
FOCUS_TOKEN_HOMOLOGACAO=       # token de Homologação (testes, notas sem valor fiscal)
FOCUS_TOKEN_PRODUCAO=          # token de Produção (notas reais)
# URLs base (opcionais — só mude se a Focus instruir)
# FOCUS_URL_HOMOLOGACAO=https://homologacao.focusnfe.com.br
# FOCUS_URL_PRODUCAO=https://api.focusnfe.com.br
