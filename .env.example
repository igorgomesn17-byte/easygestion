# ============================================================
# EasyGestão — Variáveis de Ambiente
# ============================================================
# COPIE este arquivo para .env e preencha os valores
# NUNCA comite o .env de verdade no Git (está no .gitignore)
# No Render, configure cada uma em "Environment"
#
# 🔴 OBRIGATÓRIO EM PRODUÇÃO:
#   - NODE_ENV=production
#   - SESSION_SECRET (32+ chars aleatório)
#   - ADMIN_SENHA ou ADMIN_SENHA_HASH
#   - ORIGIN (seu domínio)
# ============================================================

# --- AMBIENTE ---
# development = sem validações rígidas, fallback "dsstore" permitido
# production = OBRIGA ADMIN_SENHA ou ADMIN_SENHA_HASH
NODE_ENV=production

# --- PORTA ---
# O Render injeta automaticamente; localmente usa 3000
PORT=3000

# --- AUTENTICAÇÃO ADMIN (⚠️ OBRIGATÓRIO EM PRODUÇÃO) ---
#
# ESCOLHA UMA DAS DUAS OPÇÕES (não ambas):
#
# Opção 1: ADMIN_SENHA_HASH (recomendado - já em hash)
# Gere com: node scripts/criar-admin.js
# Formato: scrypt$<salt>$<hash>
#
# Opção 2: ADMIN_SENHA (texto plano, será hasheado ao boot)
# Requisitos: 8+ chars, maiúscula, minúscula, número, símbolo
# Exemplo: ADMIN_SENHA=SenhaForte123***REMOVED***@#
#
# ⚠️ EM PRODUÇÃO, DEIXAR VAZIO CAUSA ERRO NO BOOT***REMOVED***

ADMIN_SENHA_HASH=
ADMIN_SENHA=

# --- SEGREDO DE SESSÃO (⚠️ OBRIGATÓRIO) ---
# Mínimo 32 caracteres, alfanuméricos aleatórios
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=seu-segredo-aleatorio-com-32-caracteres-ou-mais-aqui-12345

# Diretório do banco e das fotos (disco persistente do Render = /data)
DB_DIR=/data
UPLOADS_DIR=/data/produtos

# Domínio público (para o CORS). Ex: https://oficialdsstore.com.br
ORIGIN=https://oficialdsstore.com.br

# ============================================================
# INBOX — APIs oficiais da Meta (WhatsApp Cloud API + Instagram)
# Deixe em branco enquanto não tiver: o inbox funciona em "modo
# registro" (guarda conversas), mas só ENVIA/RECEBE via Meta quando
# estas estiverem preenchidas. Obtidas no painel Meta for Developers.
# ============================================================

# --- WhatsApp Cloud API ---
WHATSAPP_TOKEN=                 # Access token (system user, longa duração)
WHATSAPP_PHONE_ID=             # PHONE_NUMBER_ID do número no WABA
WABA_ID=                       # WhatsApp Business Account ID

# --- Instagram Messaging API ---
INSTAGRAM_TOKEN=               # Access token do Instagram
INSTAGRAM_ID=                  # IG ID da conta profissional

# --- Comum aos webhooks da Meta ---
META_VERIFY_TOKEN=             # string que VOCÊ inventa (confirma o webhook na Meta)
META_APP_SECRET=               # App Secret (valida a assinatura X-Hub-Signature-256)
META_GRAPH_VERSION=v21.0       # versão da Graph API (opcional)

# ============================================================
# EMAIL — SendGrid (recuperação de senha, convites, notificações)
# Pegue a chave no painel SendGrid (Settings > API Keys).
# ============================================================
SENDGRID_API_KEY=SG.xxx_cole_sua_chave_aqui
SITE_URL=http://localhost:3000
LOJA_EMAIL=noreply@easygestao.com

# ============================================================
# TOKENS de Verificação (Email & Convites)
# Gerado automaticamente — use um secret forte (mín 32 caracteres).
# ============================================================
TOKEN_SECRET=change-me-at-least-32-chars-no-prod

# ============================================================
# CIFRA de Certificados (para dados sensíveis)
# Gerado automaticamente — use um secret forte (mín 32 caracteres).
# ============================================================
CERT_CIPHER_KEY=change-me-at-least-32-chars

# ============================================================
# NFC-e — Focus NFe (emissão de cupom fiscal eletrônico)
# Os TOKENS são segredo: pegue no painel da Focus (aba TOKENS).
# Há um token por ambiente. Deixe em branco enquanto não usar:
# o sistema só emite quando o token do ambiente atual estiver aqui.
# O ambiente atual (homologacao/producao) é escolhido na tela Config.
# ============================================================
FOCUS_TOKEN_HOMOLOGACAO=       # token de Homologação (testes, notas sem valor fiscal)
FOCUS_TOKEN_PRODUCAO=          # token de Produção (notas reais)
# URLs base (opcionais — só mude se a Focus instruir)
# FOCUS_URL_HOMOLOGACAO=https://homologacao.focusnfe.com.br
# FOCUS_URL_PRODUCAO=https://api.focusnfe.com.br

# ============================================================
# BACKUP — AWS S3 (backup automático do banco de dados)
# Deixe em branco enquanto não usar backup automatizado.
# ============================================================
AWS_BUCKET=easygestion-backups
AWS_REGION=us-east-1
AWS_ACCESS_KEY=xxx
AWS_SECRET_KEY=xxx
