    "cpf-cnpj-validator": "^2.1.2",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.4.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sqlite3": "^5.1.6",
    "stripe": "^15.12.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
