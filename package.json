{
  "name": "dre-express",
  "version": "0.1.0",
  "description": "DRE Express - SaaS para lojistas de moda (PDV + Financeiro + NFC-e)",
  "main": "server.js",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "test": "node --env-file-if-exists=.env server.js > /dev/null 2>&1 & sleep 2 && node tests/golden-path.test.js",
    "test:unit": "jest tests/validadores.test.js",
